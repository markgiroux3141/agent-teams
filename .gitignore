# Secrets
.env

# Generated run artifacts (traces, workspace output, reports) — ignore
# each entry under runs/ by default, then whitelist specific showcase
# runs we want committed. (Using runs/* instead of runs/ because git
# won't recurse into a fully-ignored directory to apply negations.)
runs/*
!runs/20260422_154916/
!runs/20260422_160700_inlined/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
